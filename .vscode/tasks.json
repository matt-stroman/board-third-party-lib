{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "tpl: dependencies up",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/scripts/dev.py",
        "up",
        "--dependencies-only"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "tpl: dependencies down",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/scripts/dev.py",
        "down"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "web: run",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/scripts/dev.py",
        "web",
        "--watch-css"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "web: status",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/scripts/dev.py",
        "web-status"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "web: stop",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/scripts/dev.py",
        "web-stop",
        "--down-dependencies"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "frontend: run",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/scripts/dev.py",
        "frontend",
        "--watch-css"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "tpl: trust dotnet dev certificate",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "dev-certs",
        "https",
        "--trust"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "backend: build debug",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/backend/src/Board.ThirdPartyLibrary.Api/Board.ThirdPartyLibrary.Api.csproj",
        "-c",
        "Debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "backend: build release",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/backend/src/Board.ThirdPartyLibrary.Api/Board.ThirdPartyLibrary.Api.csproj",
        "-c",
        "Release"
      ],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "backend: prepare debug",
      "dependsOrder": "sequence",
      "dependsOn": [
        "tpl: dependencies up",
        "backend: build debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "backend: prepare release",
      "dependsOrder": "sequence",
      "dependsOn": [
        "tpl: dependencies up",
        "backend: build release"
      ],
      "problemMatcher": []
    }
  ]
}
