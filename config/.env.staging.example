# Variables
BOARD_ENTHUSIASTS_APP_ENV=staging
BOARD_ENTHUSIASTS_SPA_BASE_URL=https://staging.boardenthusiasts.com
BOARD_ENTHUSIASTS_WORKERS_BASE_URL=https://api.staging.boardenthusiasts.com
SUPABASE_PROJECT_REF=replace-me
# Optional when using the default hosted Supabase URL for the project ref above.
# Keep SUPABASE_URL explicit for custom domains or any non-default routing.
SUPABASE_URL=https://replace-me.supabase.co
SUPABASE_PUBLISHABLE_KEY=replace-me
SUPABASE_AVATARS_BUCKET=avatars
SUPABASE_CARD_IMAGES_BUCKET=card-images
SUPABASE_HERO_IMAGES_BUCKET=hero-images
SUPABASE_LOGO_IMAGES_BUCKET=logo-images
SUPABASE_AUTH_DISCORD_CLIENT_ID=replace-me
SUPABASE_AUTH_GITHUB_CLIENT_ID=replace-me
SUPABASE_AUTH_GOOGLE_CLIENT_ID=replace-me
CLOUDFLARE_ACCOUNT_ID=replace-me
VITE_TURNSTILE_SITE_KEY=replace-me
BREVO_SIGNUPS_LIST_ID=replace-me
ALLOWED_WEB_ORIGINS=http://localhost:5173,https://staging.boardenthusiasts.com
SUPPORT_REPORT_RECIPIENT=support@boardenthusiasts.com
SUPPORT_REPORT_SENDER_EMAIL=noreply@boardenthusiasts.com
SUPPORT_REPORT_SENDER_NAME=Board Enthusiasts
VITE_LANDING_MODE=false
DEPLOY_SMOKE_PLAYER_EMAIL=testing+staging-player@boardenthusiasts.com
DEPLOY_SMOKE_DEVELOPER_EMAIL=testing+staging-developer@boardenthusiasts.com
DEPLOY_SMOKE_MODERATOR_EMAIL=testing+staging-moderator@boardenthusiasts.com

# Secrets
SUPABASE_SECRET_KEY=replace-me
SUPABASE_DB_PASSWORD=replace-me
SUPABASE_ACCESS_TOKEN=replace-me
SUPABASE_AUTH_DISCORD_CLIENT_SECRET=replace-me
SUPABASE_AUTH_GITHUB_CLIENT_SECRET=replace-me
SUPABASE_AUTH_GOOGLE_CLIENT_SECRET=replace-me
CLOUDFLARE_API_TOKEN=replace-me
TURNSTILE_SECRET_KEY=replace-me
BREVO_API_KEY=replace-me
DEPLOY_SMOKE_SECRET=replace-me
DEPLOY_SMOKE_USER_PASSWORD=replace-me
