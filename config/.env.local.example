# Variables
BOARD_ENTHUSIASTS_APP_ENV=local
BOARD_ENTHUSIASTS_SPA_BASE_URL=http://127.0.0.1:4173
BOARD_ENTHUSIASTS_WORKERS_BASE_URL=http://127.0.0.1:8787
# Keep the local Supabase URL explicit. Hosted project-ref inference is not used for local development.
SUPABASE_URL=http://127.0.0.1:55421
SUPABASE_PUBLISHABLE_KEY=replace-with-local-cli-output
SUPABASE_AVATARS_BUCKET=avatars
SUPABASE_CARD_IMAGES_BUCKET=card-images
SUPABASE_HERO_IMAGES_BUCKET=hero-images
SUPABASE_LOGO_IMAGES_BUCKET=logo-images
SUPABASE_AUTH_GITHUB_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
# Leave local Turnstile keys blank to use the development-only placeholder checkbox instead.
VITE_TURNSTILE_SITE_KEY=
BREVO_SIGNUPS_LIST_ID=
ALLOWED_WEB_ORIGINS=http://localhost:5173,http://127.0.0.1:4173
SUPPORT_REPORT_RECIPIENT=support@boardenthusiasts.com
SUPPORT_REPORT_SENDER_EMAIL=noreply@boardenthusiasts.com
SUPPORT_REPORT_SENDER_NAME=Board Enthusiasts
VITE_LANDING_MODE=false
DEPLOY_SMOKE_PLAYER_EMAIL=
DEPLOY_SMOKE_DEVELOPER_EMAIL=
DEPLOY_SMOKE_MODERATOR_EMAIL=

# Secrets
SUPABASE_SECRET_KEY=replace-with-local-cli-output
SUPABASE_DB_PASSWORD=postgres
SUPABASE_AUTH_GITHUB_CLIENT_SECRET=
SUPABASE_AUTH_GOOGLE_CLIENT_SECRET=
TURNSTILE_SECRET_KEY=
BREVO_API_KEY=
DEPLOY_SMOKE_SECRET=
DEPLOY_SMOKE_USER_PASSWORD=
